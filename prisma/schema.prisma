generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   Int                  @id @default(autoincrement())
  auth_user_id         String               @unique
  email                String               @unique
  role                 Role                 @default(user)
  created_at           DateTime             @default(now())
  password             String?
  ai_chat_sessions     AiChatSession[]
  psychiatrist_profile PsychiatristProfile?
  user_profile         UserProfile?
}

model UserProfile {
  id            Int            @id @default(autoincrement())
  user_id       Int            @unique
  name          String
  display_name  String
  sex           Sex
  location      String?
  birth_date    DateTime       @db.Date
  avatar_url    String?
  created_at    DateTime       @default(now())
  consultations Consultation[] @relation("UserConsultations")
  meeting_rooms MeetingRoom[]  @relation("UserMeetingRooms")
  user          User           @relation(fields: [user_id], references: [id])
}

model PsychiatristProfile {
  id                 Int                            @id @default(autoincrement())
  user_id            Int                            @unique
  specialization     String?
  license_number     String?
  description        String?
  experience_start   DateTime                       @db.Date
  experience_end     DateTime?                      @db.Date
  price              Int
  sex                Sex
  avatar_url         String?
  is_availability    Boolean                        @default(true)
  name               String?
  session_duration   Int?                           @default(45)
  articles           Article[]
  consultations      Consultation[]                 @relation("PsychiatristConsultations")
  meeting_rooms      MeetingRoom[]                  @relation("PsychiatristMeetingRooms")
  availability_times PsychiatristAvailabilityTime[]
  PsychiatristBreak  PsychiatristBreak[]
  expertises         PsychiatristExpertise[]
  user               User                           @relation(fields: [user_id], references: [id])
}

model Expertise {
  id                      Int                     @id @default(autoincrement())
  name                    String
  created_at              DateTime                @default(now())
  psychiatrist_expertises PsychiatristExpertise[]
}

model PsychiatristExpertise {
  id              Int                 @id @default(autoincrement())
  psychiatrist_id Int
  expertise_id    Int
  expertise       Expertise           @relation(fields: [expertise_id], references: [id])
  psychiatrist    PsychiatristProfile @relation(fields: [psychiatrist_id], references: [id])

  @@unique([psychiatrist_id, expertise_id])
}

model PsychiatristAvailabilityTime {
  id                      Int                 @id @default(autoincrement())
  psychiatrist_id         Int
  day                     Day
  availability_start_time DateTime            @db.Time(6)
  availability_end_time   DateTime            @db.Time(6)
  break_start_time        DateTime?           @db.Time(6)
  break_end_time          DateTime?           @db.Time(6)
  psychiatrist            PsychiatristProfile @relation(fields: [psychiatrist_id], references: [id])

  @@unique([psychiatrist_id, day])
}

model Consultation {
  id                    Int                    @id @default(autoincrement())
  user_id               Int
  psychiatrist_id       Int
  complaint             String?
  date                  DateTime               @db.Date
  start_time            DateTime               @db.Time(6)
  end_time              DateTime               @db.Time(6)
  topic                 String?
  feedback              String?
  created_at            DateTime               @default(now())
  diagnose              String?
  psychiatrist_feedback String?
  status                ConsultationStatus     @default(pending)
  ai_summary            String?
  consultation_context  String?
  observation_notes     String?
  session_ai_summary    String?
  consultation_notes    String?
  psychiatrist          PsychiatristProfile    @relation("PsychiatristConsultations", fields: [psychiatrist_id], references: [id])
  user                  UserProfile            @relation("UserConsultations", fields: [user_id], references: [id])
  billing               ConsultationBilling?
  medicines             ConsultationMedicine[]
}

model ConsultationBilling {
  id              Int           @id @default(autoincrement())
  consultation_id Int           @unique
  payment_method  String?
  card_holder     String?
  card_number     String?
  expire_date     String?
  cvv             String?
  subtotal        Int
  fee             Int           @default(0)
  total           Int
  status          BillingStatus @default(pending)
  created_at      DateTime      @default(now())
  consultation    Consultation  @relation(fields: [consultation_id], references: [id])
}

model ConsultationMedicine {
  id              Int          @id @default(autoincrement())
  consultation_id Int
  notes           String?
  use             String?
  dose            String?
  created_at      DateTime     @default(now())
  medicine_id     Int
  consultation    Consultation @relation(fields: [consultation_id], references: [id])
  Medicine        Medicine     @relation(fields: [medicine_id], references: [id])
}

model MeetingRoom {
  id                Int                 @id @default(autoincrement())
  user_id           Int
  user_join         Boolean             @default(false)
  psychiatrist_id   Int
  psychiatrist_join Boolean             @default(false)
  duration          Int?
  status            ConsultationStatus  @default(pending)
  created_at        DateTime            @default(now())
  end_at            DateTime?
  start_at          DateTime?
  psychiatrist      PsychiatristProfile @relation("PsychiatristMeetingRooms", fields: [psychiatrist_id], references: [id])
  user              UserProfile         @relation("UserMeetingRooms", fields: [user_id], references: [id])
  messages          Message[]
}

model Message {
  id         Int         @id @default(autoincrement())
  room_id    Int
  sender_id  Int
  message    String?
  is_read    Boolean     @default(false)
  is_edit    Boolean     @default(false)
  file_url   String?
  file_type  String?
  file_size  Int?
  created_at DateTime    @default(now())
  room       MeetingRoom @relation(fields: [room_id], references: [id])
}

model ArticleCategory {
  id         Int       @id @default(autoincrement())
  name       String
  created_at DateTime  @default(now())
  articles   Article[]
}

model ArticleCategoryTopic {
  id             Int            @id @default(autoincrement())
  name           String
  created_at     DateTime       @default(now())
  article_topics ArticleTopic[]
}

model Article {
  id              Int                 @id @default(autoincrement())
  psychiatrist_id Int
  category_id     Int
  overview        String?
  duration        Int?
  content         String?
  image_url       String?
  created_at      DateTime            @default(now())
  title           String
  status          ArticleStatus       @default(draft)
  category        ArticleCategory     @relation(fields: [category_id], references: [id])
  author          PsychiatristProfile @relation(fields: [psychiatrist_id], references: [id])
  topics          ArticleTopic[]
}

model ArticleTopic {
  id             Int                  @id @default(autoincrement())
  article_id     Int
  category_topic Int
  created_at     DateTime             @default(now())
  article        Article              @relation(fields: [article_id], references: [id])
  categoryTopic  ArticleCategoryTopic @relation(fields: [category_topic], references: [id])
}

model AiChatSession {
  id         String          @id @default(cuid())
  user_id    Int
  title      String          @default("New Chat")
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt
  messages   AiChatMessage[]
  user       User            @relation(fields: [user_id], references: [id])
}

model AiChatMessage {
  id         String        @id @default(cuid())
  session_id String
  role       String
  content    String
  created_at DateTime      @default(now())
  session    AiChatSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Medicine {
  id                   Int                    @id @default(autoincrement())
  name                 String                 @unique
  description          String?
  created_at           DateTime               @default(now())
  ConsultationMedicine ConsultationMedicine[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model PsychiatristBreak {
  id                  Int                 @id @default(autoincrement())
  psychiatrist_id     Int
  date                DateTime            @db.Date
  start_time          DateTime?           @db.Time(6)
  end_time            DateTime?           @db.Time(6)
  is_full_day         Boolean             @default(true)
  note                String?
  created_at          DateTime            @default(now())
  PsychiatristProfile PsychiatristProfile @relation(fields: [psychiatrist_id], references: [id])
}

enum Role {
  user
  psychiatry
}

enum Sex {
  male
  female
}

enum Day {
  sunday
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
}

enum ConsultationStatus {
  pending
  on_going
  finished
  draft
  published
}

enum ArticleStatus {
  draft
  published
}

enum BillingStatus {
  pending
  paid
  canceled
  expired
}
